{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LibreRTC Client",
  "version": "0.1.0",
  "identifier": "com.svllvsxprod.librertc.client",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LibreRTC Client",
        "width": 800,
        "height": 600,
        "minWidth": 800,
        "minHeight": 600,
        "maxWidth": 800,
        "maxHeight": 600,
        "resizable": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": ["icons/icon.ico", "icons/icon.png"]
  }
}
